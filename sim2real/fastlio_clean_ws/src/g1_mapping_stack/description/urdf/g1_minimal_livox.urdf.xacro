<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="g1_minimal_livox">

  <!-- Minimal fallback model so the stack can run even before you add the full G1 URDF. -->
  <xacro:arg name="base_z" default="0.0"/>
  <xacro:arg name="lidar_x" default="0.15"/>
  <xacro:arg name="lidar_y" default="0.00"/>
  <xacro:arg name="lidar_z" default="0.85"/>
  <xacro:arg name="lidar_roll" default="0.0"/>
  <xacro:arg name="lidar_pitch" default="0.0"/>
  <xacro:arg name="lidar_yaw" default="0.0"/>

  <link name="base_footprint"/>

  <link name="base_link">
    <visual>
      <origin xyz="0 0 0.45" rpy="0 0 0"/>
      <geometry>
        <box size="0.30 0.22 0.90"/>
      </geometry>
      <material name="gray">
        <color rgba="0.5 0.5 0.5 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0.45" rpy="0 0 0"/>
      <geometry>
        <box size="0.30 0.22 0.90"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0.45" rpy="0 0 0"/>
      <mass value="35.0"/>
      <inertia ixx="2.0" ixy="0.0" ixz="0.0" iyy="2.0" iyz="0.0" izz="1.0"/>
    </inertial>
  </link>

  <joint name="base_footprint_to_base_link" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0 0 $(arg base_z)" rpy="0 0 0"/>
  </joint>

  <link name="livox_frame">
    <visual>
      <geometry>
        <box size="0.08 0.08 0.05"/>
      </geometry>
      <material name="blue">
        <color rgba="0.1 0.3 0.9 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <box size="0.08 0.08 0.05"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.3"/>
      <inertia ixx="0.001" ixy="0.0" ixz="0.0" iyy="0.001" iyz="0.0" izz="0.001"/>
    </inertial>
  </link>

  <joint name="base_link_to_livox_frame" type="fixed">
    <parent link="base_link"/>
    <child link="livox_frame"/>
    <origin xyz="$(arg lidar_x) $(arg lidar_y) $(arg lidar_z)"
            rpy="$(arg lidar_roll) $(arg lidar_pitch) $(arg lidar_yaw)"/>
  </joint>

</robot>
